+MARKDOWN_EXAMPLE_PATH = ROOT / "examples" / "plan.workflow.explanation.md"
+
+
+def _load(path: Path):
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def _buffer_workflow(layer_name="sites"):
+    return {
+        "version": 1,
+        "steps": [
+            {
+                "operation": "buffer",
+                "inputs": {"input": layer_name},
+                "parameters": {
+                    "distance": 10,
+                    "source_crs": "EPSG:3857",
+                    "work_crs": "EPSG:3857",
+                },
+                "output": "buffers",
+            }
+        ],
+    }
+
+
+def test_workflow_explanation_schema_is_valid_and_report_conforms():
+    schema = _load(EXPLANATION_SCHEMA_PATH)
+    Draft202012Validator.check_schema(schema)
+    explanation = explain_workflow(
+        _load(PLAN_WORKFLOW_PATH), {"source", "mask", "unused"}
+    )
+    Draft202012Validator(schema).validate(explanation)
+
+
+def test_explanation_reuses_plan_and_graph_evidence_with_stable_steps():
+    workflow = _load(PLAN_WORKFLOW_PATH)
+    layers = {"source", "mask", "unused"}
+    plan = plan_workflow(workflow, layers)
+    graph = build_workflow_graph(workflow, layers)
+    explanation = explain_workflow(workflow, layers)
+
+    assert explanation["schema_version"] == WORKFLOW_EXPLANATION_VERSION
+    assert explanation["workflow_digest"] == plan["workflow_digest"]
+    assert explanation["plan_digest"] == plan["plan_digest"]
+    assert explanation["graph_digest"] == graph["graph_digest"]
+    assert explanation["required_external_layers"] == ["mask", "source"]
+    assert explanation["unused_external_layers"] == ["unused"]
+    assert explanation["terminal_layers"] == ["coverage"]
+    assert explanation["all_steps_deterministic"] is True
+
+    assert explanation["steps"][0] == {
+        "index": 0,
+        "operation": "reproject",
+        "summary": "Transform every geometry to a target CRS while preserving properties and order.",
+        "deterministic": True,
+        "dependencies": [],
+        "inputs": [
+            {"name": "input", "layer": "source", "source_kind": "external"}
+        ],
+        "parameters": [
+            {"name": "target_crs", "value": "EPSG:3857", "source": "provided"},
+            {"name": "source_crs", "value": None, "source": "default"},
