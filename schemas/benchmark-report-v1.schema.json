{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liu2024whu-bit/starshine/schemas/benchmark-report-v1.schema.json",
  "title": "Starshine Geo small-vector benchmark report version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "corpus_version",
    "corpus_digest",
    "starshine_version",
    "python",
    "platform",
    "repeat_count",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "corpus_version": {
      "const": 4
    },
    "corpus_digest": {
      "$ref": "#/$defs/digest"
    },
    "starshine_version": {
      "type": "string",
      "minLength": 1
    },
    "python": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation",
        "version"
      ],
      "properties": {
        "implementation": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "machine"
      ],
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1
        },
        "machine": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "repeat_count": {
      "type": "integer",
      "minimum": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "timingSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "samples_seconds",
        "minimum_seconds",
        "median_seconds"
      ],
      "properties": {
        "samples_seconds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number",
            "minimum": 0
          }
        },
        "minimum_seconds": {
          "type": "number",
          "minimum": 0
        },
        "median_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "case_digest",
        "input_layer_count",
        "input_feature_count",
        "operation_count",
        "output_layer",
        "output_feature_count",
        "semantic_digest",
        "output_digest",
        "timing"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "case_digest": {
          "$ref": "#/$defs/digest"
        },
        "input_layer_count": {
          "type": "integer",
          "minimum": 1
        },
        "input_feature_count": {
          "type": "integer",
          "minimum": 1
        },
        "operation_count": {
          "type": "integer",
          "minimum": 1
        },
        "output_layer": {
          "type": "string",
          "minLength": 1
        },
        "output_feature_count": {
          "type": "integer",
          "minimum": 1
        },
        "semantic_digest": {
          "$ref": "#/$defs/digest"
        },
        "output_digest": {
          "$ref": "#/$defs/digest"
        },
        "timing": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "validation_only",
            "validated_run"
          ],
          "properties": {
            "validation_only": {
              "$ref": "#/$defs/timingSummary"
            },
            "validated_run": {
              "$ref": "#/$defs/timingSummary"
            }
          }
        }
      }
    }
  }
}
