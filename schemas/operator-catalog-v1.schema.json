{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liu2024whu-bit/starshine/schemas/operator-catalog-v1.schema.json",
  "title": "Starshine Geo operator catalog version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_version",
    "operators"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "workflow_version": {
      "const": 1
    },
    "operators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/operator"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "contract"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "contract": {
          "$ref": "#/$defs/inputContract"
        }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "required",
        "schema",
        "sensitive"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "required": {
          "type": "boolean"
        },
        "schema": {
          "type": "object"
        },
        "default": {},
        "sensitive": {
          "type": "boolean"
        }
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "summary",
        "inputs",
        "parameters",
        "output_crs",
        "deterministic"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/input"
          }
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        },
        "output_crs": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "deterministic": {
          "type": "boolean"
        }
      }
    },
    "fieldRequirementSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameter",
        "unique",
        "non_null",
        "finite_json_scalar"
      ],
      "properties": {
        "parameter": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "unique": {
          "type": "boolean"
        },
        "non_null": {
          "type": "boolean"
        },
        "finite_json_scalar": {
          "type": "boolean"
        }
      }
    },
    "fieldWriteSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collision_policy"
      ],
      "properties": {
        "parameter": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "collision_policy": {
          "type": "string",
          "enum": [
            "reject",
            "overwrite"
          ]
        }
      },
      "oneOf": [
        {
          "required": [
            "parameter"
          ],
          "not": {
            "required": [
              "name"
            ]
          }
        },
        {
          "required": [
            "name"
          ],
          "not": {
            "required": [
              "parameter"
            ]
          }
        }
      ]
    },
    "inputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "geometry_types",
        "crs",
        "required_fields",
        "written_fields",
        "notes"
      ],
      "properties": {
        "geometry_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "uniqueItems": true
        },
        "crs": {
          "$ref": "#/$defs/inputCrsContract"
        },
        "required_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldRequirementSpec"
          }
        },
        "written_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldWriteSpec"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "inputCrsContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "declared",
            "projected",
            "parameter",
            "declared_or_parameter"
          ]
        },
        "parameter": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "equivalent_to_input": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
