{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liu2024whu-bit/starshine/schemas/workflow-explanation-v1.schema.json",
  "title": "Starshine Geo workflow explanation version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_version",
    "workflow_digest",
    "operator_catalog_version",
    "operator_catalog_digest",
    "plan_digest",
    "graph_digest",
    "declared_external_layers",
    "required_external_layers",
    "unused_external_layers",
    "produced_layers",
    "terminal_layers",
    "step_count",
    "all_steps_deterministic",
    "steps",
    "remaining_checks",
    "explanation_digest"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "workflow_version": {"const": 1},
    "workflow_digest": {"$ref": "#/$defs/digest"},
    "operator_catalog_version": {"const": 1},
    "operator_catalog_digest": {"$ref": "#/$defs/digest"},
    "plan_digest": {"$ref": "#/$defs/digest"},
    "graph_digest": {"$ref": "#/$defs/digest"},
    "declared_external_layers": {"$ref": "#/$defs/layerList"},
    "required_external_layers": {"$ref": "#/$defs/layerList"},
    "unused_external_layers": {"$ref": "#/$defs/layerList"},
    "produced_layers": {"$ref": "#/$defs/layerList"},
    "terminal_layers": {"$ref": "#/$defs/layerList"},
    "step_count": {"type": "integer", "minimum": 1},
    "all_steps_deterministic": {"type": "boolean"},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/step"}
    },
    "remaining_checks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonEmptyString"}
    },
    "explanation_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "layerList": {
      "type": "array",
      "items": {"$ref": "#/$defs/nonEmptyString"},
      "uniqueItems": true
    },
    "externalInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "layer", "source_kind"],
      "properties": {
        "name": {"$ref": "#/$defs/nonEmptyString"},
        "layer": {"$ref": "#/$defs/nonEmptyString"},
        "source_kind": {"const": "external"}
      }
    },
    "stepInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "layer", "source_kind", "producer_step"],
      "properties": {
        "name": {"$ref": "#/$defs/nonEmptyString"},
        "layer": {"$ref": "#/$defs/nonEmptyString"},
        "source_kind": {"const": "step"},
        "producer_step": {"type": "integer", "minimum": 0}
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value", "source"],
      "properties": {
        "name": {"$ref": "#/$defs/nonEmptyString"},
        "value": {},
        "source": {"enum": ["provided", "default"]}
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "operation",
        "summary",
        "deterministic",
        "dependencies",
        "inputs",
        "parameters",
        "output",
        "output_crs",
        "terminal"
      ],
      "properties": {
        "index": {"type": "integer", "minimum": 0},
        "operation": {"$ref": "#/$defs/nonEmptyString"},
        "summary": {"$ref": "#/$defs/nonEmptyString"},
        "deterministic": {"type": "boolean"},
        "dependencies": {
          "type": "array",
          "items": {"type": "integer", "minimum": 0},
          "uniqueItems": true
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {"$ref": "#/$defs/externalInput"},
              {"$ref": "#/$defs/stepInput"}
            ]
          }
        },
        "parameters": {
          "type": "array",
          "items": {"$ref": "#/$defs/parameter"}
        },
        "output": {"$ref": "#/$defs/nonEmptyString"},
        "output_crs": {"$ref": "#/$defs/nonEmptyString"},
        "terminal": {"type": "boolean"}
      }
    }
  }
}
